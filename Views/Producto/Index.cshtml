@model List<PainHead.Models.Producto>

@{
    ViewData["Title"] = "Productos";
}

<h2>Lista de Productos</h2>

<div>
    <a asp-action="Create" class="btn btn-primary">Crear Nuevo Producto</a>
</div>

<br />

<table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Precio</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var producto in Model)
        {
            <tr>
                <td>@producto.Id</td>
                <td>@producto.Nombre</td>
                <td style="white-space: normal; word-break: break-word; max-width: 400px;">
                    @producto.Descripcion
                </td>
                <td>@producto.Precio.ToString("C")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@producto.Id">Editar</a> |
                    <a asp-action="Delete" asp-route-id="@producto.Id">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>