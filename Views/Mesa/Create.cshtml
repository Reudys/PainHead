@model PainHead.Models.Mesa

@{
    ViewData["Title"] = "Nueva Mesa";
}

<h2>Crear Nueva Mesa</h2>

<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label"></label>
                <input asp-for="Nombre" class="form-control" placeholder="Ej: Mesa VIP, Terraza, etc." />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Número de Mesa</label>
                <input type="text" class="form-control" value="(Se asignará automáticamente)" disabled />
                <small class="text-muted">El número se generará automáticamente</small>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Crear Mesa</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}